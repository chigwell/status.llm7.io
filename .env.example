# Use the Vite dev proxy for the real API during local development.
VITE_LLM7_PING_ENDPOINT=/llm7-ping/ping

# Use this for a fully local demo when DNS/API access is unavailable.
# VITE_LLM7_PING_ENDPOINT=/mock-ping

# Use this only when the API allows browser CORS, or behind your production edge route.
# VITE_LLM7_PING_ENDPOINT=https://api.llm7.io/ping
